# ============================================
# DATABASE CONFIGURATION (OPTIONAL)
# ============================================
# NOTE: Database configuration is OPTIONAL. The application will start
# successfully without a database connection. When database is unavailable,
# database-dependent features will return HTTP 503 errors.
#
# Health check endpoint (/health) is always available for monitoring.

# For PostgreSQL (Neon) - Recommended for production
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require&channel_binding=require

# OR use individual PostgreSQL components (if DATABASE_URL not set)
POSTGRES_HOST=your_neon_host.neon.tech
POSTGRES_PORT=5432
POSTGRES_USER=neondb_owner
POSTGRES_PASSWORD=your_password
POSTGRES_DATABASE=deo_chatbot
POSTGRES_SSLMODE=require

# For MySQL (Legacy - not recommended)
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your_password
# MYSQL_DATABASE=deo_chatbot

# ============================================
# APPLICATION SETTINGS
# ============================================
SECRET_KEY=deo_chatbot_secret_key_2024
MASTER_PASSWORD=Admin@123
SESSION_TIMEOUT=20
MASTER_OTP=000000

# ============================================
# GOOGLE GEMINI API
# ============================================
GEMINI_API_KEY=your_gemini_api_key

# ============================================
# EMAIL CONFIGURATION (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_APP_PASSWORD=your_app_password

# ============================================
# ROLE-BASED EMAIL CREDENTIALS
# ============================================
# DEO Email: 231fa04436@gmail.com
DEO_EMAIL_PASSWORD=your_deo_app_password

# HOD Email: 231fa04476@gmail.com
HOD_EMAIL_PASSWORD=your_hod_app_password

# Admin Email: 231fa04446@gmail.com
ADMIN_EMAIL_PASSWORD=your_admin_app_password

